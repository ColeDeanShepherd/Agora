[
  {
    "id": "vti-snapshot",
    "title": "VTI Snapshot",
    "expression": "'https://www.google.com/finance/quote/VTI:NYSEARCA'",
    "render": "(value) => ({ webviewUrl: value })",
    "rect": {
      "position": {
        "x": 0,
        "y": 0
      },
      "size": {
        "width": 640,
        "height": 480
      }
    }
  },
  {
    "id": "clock",
    "title": "Clock",
    "expression": "new Date()",
    "schedule": { "type": "interval", "intervalMs": 1000 },
    "render": "(value) => `<span class=\"clock-display\">${value.toLocaleTimeString()}</span>`",
    "rect": {
      "position": {
        "x": 660,
        "y": 0
      },
      "size": {
        "width": 280,
        "height": 120
      }
    }
  },
  {
    "id": "clock-plus-1hr",
    "title": "Clock +1 Hr",
    "expression": "new Date(inputs.clock.getTime() + 60 * 60 * 1000)",
    "schedule": { "type": "inputChange" },
    "inputs": { "clock": "clock" },
    "render": "(value) => `<span class=\"clock-display\">${value.toLocaleTimeString()}</span>`",
    "rect": {
      "position": {
        "x": 960,
        "y": 0
      },
      "size": {
        "width": 280,
        "height": 120
      }
    }
  },
  {
    "id": "google-time",
    "title": "Google Time",
    "expression": "new Date(Math.floor(inputs.clock.getTime() / 30000) * 30000)",
    "schedule": { "type": "inputChange" },
    "inputs": { "clock": "clock" },
    "render": "(value) => ({ webviewUrl: `https://www.google.com/search?igu=1&q=${encodeURIComponent(value.toLocaleTimeString())}` })",
    "rect": {
      "position": {
        "x": 660,
        "y": 140
      },
      "size": {
        "width": 640,
        "height": 480
      }
    }
  },
  {
    "id": "resume",
    "title": "Resume PDF",
    "expression": "api.readPdf('/home/cole/Downloads/resume.pdf')",
    "render": "(value) => ({ webviewUrl: `file://${value.path}` })",
    "rect": {
      "position": {
        "x": 0,
        "y": 500
      },
      "size": {
        "width": 640,
        "height": 480
      }
    }
  },
  {
    "id": "resume-seattle-count",
    "title": "Seattle Count",
    "expression": "(inputs.resume.text.match(/Seattle/gi) || []).length",
    "schedule": { "type": "inputChange" },
    "inputs": { "resume": "resume" },
    "render": "(value) => `<span class=\"clock-display\">\"Seattle\" found ${value} time(s)</span>`",
    "rect": {
      "position": {
        "x": 660,
        "y": 640
      },
      "size": {
        "width": 280,
        "height": 120
      }
    }
  },
  {
    "id": "dl-front",
    "title": "DL Front",
    "expression": "api.readImage('/home/cole/Downloads/dl_front.jpg')",
    "render": "(value) => `<img class=\"panel-image\" src=\"${value.dataUrl}\" />`",
    "rect": {
      "position": {
        "x": 0,
        "y": 1000
      },
      "size": {
        "width": 640,
        "height": 480
      }
    }
  },
  {
    "id": "dl-front-blur",
    "title": "DL Front (Blurred)",
    "expression": "inputs.image",
    "schedule": { "type": "inputChange" },
    "inputs": { "image": "dl-front" },
    "render": "(value) => `<img class=\"panel-image blurred\" src=\"${value.dataUrl}\" />`",
    "rect": {
      "position": {
        "x": 660,
        "y": 1000
      },
      "size": {
        "width": 640,
        "height": 480
      }
    }
  }
]
